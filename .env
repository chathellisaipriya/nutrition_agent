# .env.example
# Copy this file to .env and fill in your actual values.
# Never commit .env to version control.

# ── Flask ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your-flask-secret-key-here
DEBUG=False
PORT=5000

# ── IBM watsonx.ai ────────────────────────────────────────────────────────────
IBM_API_KEY=YOUR IBM_API_KEY
PROJECT_ID=YOUR PROJECT_ID
IBM_URL=https://au-syd.ml.cloud.ibm.com

# ── Granite model ─────────────────────────────────────────────────────────────
MODEL_ID=meta-llama/llama-3-3-70b-instruct

# ── LLM generation parameters (optional overrides) ────────────────────────────
LLM_MAX_NEW_TOKENS=1024
LLM_MIN_NEW_TOKENS=50
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_TOP_K=50
LLM_REPETITION_PENALTY=1.1

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URI=sqlite:///database/nutrition.db

# ── RAG / Vector store ────────────────────────────────────────────────────────
RAG_DATA_DIR=rag/data
FAISS_INDEX_DIR=rag/faiss_index
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=4

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_FOLDER=uploads
